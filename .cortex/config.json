{
  "version": "1.0",
  "features": {
    "cloud_models": false,
    "openrouter": false,
    "checkpoints": false,
    "environments": true,
    "plugins": true,
    "skills": true
  },
  "providers": {
    "openrouter": {
      "enabled": false,
      "api_key_env": "OPENROUTER_API_KEY"
    }
  },
  "routing": {
    "prefer_local": true,
    "allow_cloud_fallback": true
  }
}